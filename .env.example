# OmegaAPI — Environment Variables
# Copy this to .env.local and fill in the values.

# ── Upstream API ──
# No configuration needed — OmegaScans API is public.

# ── Vercel KV (Optional) ──
# Used for persistent device binding across serverless cold starts.
# Get these from your Vercel dashboard → Storage → KV.
# KV_REST_API_URL=
# KV_REST_API_TOKEN=

# ── Access Codes (Optional) ──
# Comma-separated access codes for premium plans.
# ACCESS_CODES=
# ACCESS_CODES_HOURLY=
# ACCESS_CODES_DAILY=
# ACCESS_CODES_WEEKLY=
# ACCESS_CODES_MONTHLY=
# ACCESS_CODES_QUARTERLY=
# ACCESS_CODES_DEV=
